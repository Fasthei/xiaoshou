# ==== 应用 ====
APP_NAME=销售系统
APP_VERSION=1.0.0
DEBUG=False

# ==== 数据库 ====
DATABASE_URL=postgresql://user:password@localhost:5432/sales_system

# ==== Redis ====
REDIS_URL=redis://localhost:6379/0

# ==== 本地 JWT (仅用于开发/退化模式，生产由 Casdoor 签发) ====
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==== Casdoor 认证 ====
# 认证总开关：true=强制认证，false=跳过（本地调试用）
AUTH_ENABLED=true

CASDOOR_ENDPOINT=https://casdoor.ashyglacier-8207efd2.eastasia.azurecontainerapps.io
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_ORG=built-in
CASDOOR_APP_NAME=xiaoshou
# 前端回调 URI（需在 Casdoor 应用配置里登记）
CASDOOR_REDIRECT_URI=http://localhost:8000/api/auth/callback
# 可选：如自动拉取 JWKS 有问题，可直接贴 Casdoor 应用的 公钥 PEM
CASDOOR_CERT=

# ==== CORS ====
# 逗号分隔；生产务必收紧
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==== Jina (搜索 + Reader，客户洞察 agent 的工具之一) ====
JINA_API_KEY=

# ==== LinkedIn via RapidAPI (客户洞察 agent 的工具之二) ====
RAPIDAPI_KEY=
LINKEDIN_API_HOST=fresh-linkedin-profile-data.p.rapidapi.com

# ==== Azure OpenAI (客户洞察 agent 的大脑, gpt-5.4) ====
# endpoint 只需要 host, 不要带 /openai/... 路径
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# ==== SMTP 邮件 ====
SMTP_SERVER=smtp.189.cn
SMTP_PORT=465
SMTP_EMAIL=taijiagent@189.cn
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_FROM_NAME=销售系统

# ==== 超级运营中心 (external API) ====
# 给 /api/external/* 用的 X-Api-Key, 超运侧拿到后配置进他们的环境变量
SUPER_OPS_API_KEY=
